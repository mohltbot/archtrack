{
  "name": "KlearNow - Document Verification",
  "description": "Auto-check customs documents for compliance, flag issues, route for review",
  "version": "2.0",
  "nodes": [
    {
      "id": "uploadTrigger",
      "type": "n8n-nodes-base.googleDriveTrigger",
      "name": "Document Uploaded",
      "parameters": {
        "event": "fileCreated",
        "folder": "Customs-Documents"
      }
    },
    {
      "id": "classify",
      "type": "n8n-nodes-base.aiTransform",
      "name": "Classify Document",
      "parameters": {
        "text": "={{ $json.name }}",
        "categories": "Commercial Invoice, Packing List, Bill of Lading, Certificate of Origin, Customs Declaration"
      }
    },
    {
      "id": "extractData",
      "type": "n8n-nodes-base.documentParser",
      "name": "Extract Data",
      "parameters": {
        "document": "={{ $json.file }}"
      }
    },
    {
      "id": "validate",
      "type": "n8n-nodes-base.function",
      "name": "Validate Compliance",
      "parameters": {
        "functionCode": "const doc = $input.first().json;\nconst errors = [];\n\n// Required fields check\nif (!doc.hsCode) errors.push('Missing HS Code');\nif (!doc.value) errors.push('Missing declared value');\nif (!doc.countryOfOrigin) errors.push('Missing country of origin');\n\n// Value threshold check\nif (doc.value > 2500 && !doc.ein) errors.push('EIN required for high-value');\n\n// Restricted items check\nconst restricted = ['weapons', 'drugs', 'counterfeit'];\nif (restricted.some(r => doc.description?.toLowerCase().includes(r))) {\n  errors.push('POTENTIAL RESTRICTED ITEM');\n}\n\nreturn { valid: errors.length === 0, errors, doc };"
      }
    },
    {
      "id": "route",
      "type": "n8n-nodes-base.switch",
      "name": "Route by Status",
      "parameters": {
        "rules": [
          {"value": "valid", "output": 0},
          {"value": "invalid", "output": 1}
        ]
      }
    },
    {
      "id": "approve",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Mark Approved",
      "parameters": {
        "operation": "append",
        "sheetId": "cleared-documents",
        "range": "Cleared!A:D",
        "values": [
          "={{ $now }}",
          "={{ $json.doc.fileName }}",
          "APPROVED",
          "={{ $json.doc.hsCode }}"
        ]
      }
    },
    {
      "id": "flagReview",
      "type": "n8n-nodes-base.slack",
      "name": "Alert Customs Team",
      "parameters": {
        "channel": "#customs-review",
        "text": "⚠️ DOCUMENT NEEDS REVIEW\nFile: {{ $json.doc.fileName }}\nErrors: {{ $json.errors.join(', ') }}\nPriority: {{ $json.errors.includes('POTENTIAL RESTRICTED ITEM') ? 'HIGH' : 'NORMAL' }}"
      }
    },
    {
      "id": "updateStatus",
      "type": "n8n-nodes-base.googleDrive",
      "name": "Move to Reviewed",
      "parameters": {
        "operation": "move",
        "fileId": "={{ $json.doc.id }}",
        "folder": "Reviewed-Documents"
      }
    }
  ],
  "connections": {
    "uploadTrigger": {"main": [[{"node": "classify", "type": "main", "index": 0}]]},
    "classify": {"main": [[{"node": "extractData", "type": "main", "index": 0}]]},
    "extractData": {"main": [[{"node": "validate", "type": "main", "index": 0}]]},
    "validate": {"main": [[{"node": "route", "type": "main", "index": 0}]]},
    "route": {
      "main": [
        [{"node": "approve", "type": "main", "index": 0}],
        [{"node": "flagReview", "type": "main", "index": 0}]
      ]
    },
    "approve": {"main": [[{"node": "updateStatus", "type": "main", "index": 0}]]},
    "flagReview": {"main": [[{"node": "updateStatus", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "KlearNow",
    "useCase": "Document Verification",
    "version": "2.0",
    "nodes": 8,
    "author": "Mission Control",
    "status": "production-ready"
  }
}
