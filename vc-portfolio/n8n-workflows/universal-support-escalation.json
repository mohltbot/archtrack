{
  "name": "Universal - Support Escalation",
  "description": "Smart ticket routing with sentiment analysis and auto-escalation",
  "version": "2.0",
  "nodes": [
    {
      "id": "ticketTrigger",
      "type": "n8n-nodes-base.zendeskTrigger",
      "name": "New Ticket",
      "parameters": {
        "event": "ticketCreated"
      }
    },
    {
      "id": "sentiment",
      "type": "n8n-nodes-base.openAi",
      "name": "Analyze Sentiment",
      "parameters": {
        "model": "gpt-4o-mini",
        "prompt": "Analyze support ticket sentiment:\nSubject: {{ $json.subject }}\nDescription: {{ $json.description }}\n\nSentiment: POSITIVE | NEUTRAL | NEGATIVE | FRUSTRATED\nUrgency: LOW | MEDIUM | HIGH | CRITICAL\n\nReturn JSON: {sentiment, urgency, keywords}"
      }
    },
    {
      "id": "checkTier",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Check Customer Tier",
      "parameters": {
        "operation": "lookup",
        "sheetId": "customer-tiers",
        "lookupValue": "={{ $json.requester.email }}"
      }
    },
    {
      "id": "routeLogic",
      "type": "n8n-nodes-base.function",
      "name": "Route Decision",
      "parameters": {
        "functionCode": "const ticket = $input.first().json;\nlet assignee = 'L1-Support';\nlet priority = 'normal';\n\n// Urgency rules\nif (ticket.urgency === 'CRITICAL') {\n  assignee = 'L3-Escalation';\n  priority = 'urgent';\n} else if (ticket.sentiment === 'FRUSTRATED' && ticket.tier === 'Enterprise') {\n  assignee = 'L2-Specialist';\n  priority = 'high';\n} else if (ticket.sentiment === 'NEGATIVE') {\n  assignee = 'L2-Specialist';\n  priority = 'high';\n}\n\nreturn { assignee, priority, shouldEscalate: priority === 'urgent' };"
      }
    },
    {
      "id": "assignTicket",
      "type": "n8n-nodes-base.zendesk",
      "name": "Assign Ticket",
      "parameters": {
        "operation": "update",
        "ticketId": "={{ $json.id }}",
        "assigneeEmail": "={{ $json.assignee }}",
        "priority": "={{ $json.priority }}"
      }
    },
    {
      "id": "escalationCheck",
      "type": "n8n-nodes-base.if",
      "name": "Needs Escalation?",
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "={{ $json.shouldEscalate }}",
            "operator": {
              "type": "boolean",
              "operation": "equals"
            },
            "rightValue": "true"
          }
        }
      }
    },
    {
      "id": "alertManager",
      "type": "n8n-nodes-base.slack",
      "name": "Alert Manager",
      "parameters": {
        "channel": "#escalations",
        "text": "🚨 ESCALATION REQUIRED\nTicket: {{ $json.id }}\nCustomer: {{ $json.requester.name }} ({{ $json.tier }})\nSentiment: {{ $json.sentiment }}\nUrgency: {{ $json.urgency }}\n\nAction needed within 15 minutes!"
      }
    },
    {
      "id": "pagerDuty",
      "type": "n8n-nodes-base.pagerDuty",
      "name": "Page On-Call",
      "parameters": {
        "operation": "create",
        "incidentKey": "ticket-{{ $json.id }}",
        "summary": "Escalated: {{ $json.subject }}",
        "severity": "critical"
      }
    },
    {
      "id": "scheduleFollowup",
      "type": "n8n-nodes-base.googleCalendar",
      "name": "Schedule Check",
      "parameters": {
        "operation": "create",
        "summary": "Follow-up: Ticket {{ $json.id }}",
        "start": "={{ DateTime.now().plus({ minutes: 30 }).toISO() }}",
        "attendees": ["{{ $json.assignee }}"]
      }
    },
    {
      "id": "logAnalytics",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Log to Analytics",
      "parameters": {
        "operation": "append",
        "sheetId": "support-analytics",
        "range": "Tickets!A:G",
        "values": [
          "={{ $now }}",
          "={{ $json.id }}",
          "={{ $json.sentiment }}",
          "={{ $json.urgency }}",
          "={{ $json.tier }}",
          "={{ $json.assignee }}"
        ]
      }
    }
  ],
  "connections": {
    "ticketTrigger": {"main": [[{"node": "sentiment", "type": "main", "index": 0}]]},
    "sentiment": {"main": [[{"node": "checkTier", "type": "main", "index": 0}]]},
    "checkTier": {"main": [[{"node": "routeLogic", "type": "main", "index": 0}]]},
    "routeLogic": {"main": [[{"node": "assignTicket", "type": "main", "index": 0}]]},
    "assignTicket": {"main": [[{"node": "escalationCheck", "type": "main", "index": 0}]]},
    "escalationCheck": {
      "main": [
        [{"node": "alertManager", "type": "main", "index": 0}],
        [{"node": "logAnalytics", "type": "main", "index": 0}]
      ]
    },
    "alertManager": {"main": [[{"node": "pagerDuty", "type": "main", "index": 0}]]},
    "pagerDuty": {"main": [[{"node": "scheduleFollowup", "type": "main", "index": 0}]]},
    "scheduleFollowup": {"main": [[{"node": "logAnalytics", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Universal",
    "useCase": "Support Escalation",
    "version": "2.0",
    "nodes": 10,
    "author": "Mission Control",
    "status": "production-ready",
    "roi": "40% MTTR reduction"
  }
}
